<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--        Discipline Category Search View-->
    <record id="discipline_category_view_search" model="ir.ui.view">
        <field name="name">discipline.category.view.search</field>
        <field name="model">discipline.category</field>
        <field name="arch" type="xml">
            <search string="Search information">
                <field name="name"/>
                <field name="code"/>
                <field name="category_type"/>
                <field name="description"/>
                <filter string="Category" name="department_name"
                        context="{'group_by':'category_type'}"/>
            </search>
        </field>
    </record>
    <!--Discipline Category Tree View-->
    <record id="discipline_category_view_list" model="ir.ui.view">
        <field name="name">discipline.category.view.list</field>
        <field name="model">discipline.category</field>
        <field name="arch" type="xml">
            <list string="Discipline Categories">
                <field name="name"/>
            </list>
        </field>
    </record>
    <!--        Discipline Category Form View-->
    <record id="disciplinary_category_view_form" model="ir.ui.view">
        <field name="name">discipline.category.view.form</field>
        <field name="model">discipline.category</field>
        <field name="arch" type="xml">
            <form string="Discipline Category">
                <sheet>
                    <group>
                        <field name="name" required="True"/>
                        <field name="code" required="True"/>
                        <field name="category_type" required="True"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--        Discipline Category Action-->
    <record id="discipline_category_action"
            model="ir.actions.act_window">
        <field name="name">Discipline Categories</field>
        <field name="res_model">discipline.category</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_department_name': 1}</field>
    </record>
    <!--        Discipline Category Menuitem-->
    <menuitem id="disciplinary_category_view"
              action="discipline_category_action"
              groups="hr.group_hr_manager" name="Discipline Category"
              parent="disciplinary_action"
              sequence="3"/>
</odoo>
