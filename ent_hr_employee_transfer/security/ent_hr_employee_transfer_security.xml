<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Employee multi company rule-->
    <record id="employee_rule" model="ir.rule">
        <field name="name">Employee Multi Company Rule</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=',
            False),('company_id', 'in', company_ids)]
        </field>
    </record>
    <!--Contract multi company rule-->
    <record id="employee_contract_rule" model="ir.rule">
        <field name="name">Contract Multi Company Rule</field>
        <field name="model_id" ref="hr_contract.model_hr_contract"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=',
            False),('company_id', 'in', company_ids)]
        </field>
    </record>
</odoo>
