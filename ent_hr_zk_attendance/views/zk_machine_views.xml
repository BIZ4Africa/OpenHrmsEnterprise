<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Form view for zk.machine-->
    <record id="zk_machine_view_form" model="ir.ui.view">
        <field name="name">zk.machine.view.form</field>
        <field name="model">zk.machine</field>
        <field name="arch" type="xml">
            <form string="Biometric Device">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="oe_highlight"/>
                    <button name="action_import_attendance" type="object"
                            string="Import Data" class="oe_highlight"
                            icon="fa-download "
                            confirm="Are you sure you want to do this?"/>
                    <button name="action_clear_attendance" type="object"
                            string="Clear Data" icon="fa-remove "
                            confirm="Are you sure you want to do this?"/>
                    <button name="action_restart_device" type="object"
                            string="Restart Device" icon="fa-refresh "
                            confirm="Are you sure you want to do this?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Machine IP"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="port_no"/>
                            <field name="address_id"/>
                            <field name="active" widget="toggle"/>
                        </group>
                        <group>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--List view for zk.machine for showing the device details-->
    <record id="zk_machine_view_list" model="ir.ui.view">
        <field name="name">zk.machine.view.list</field>
        <field name="model">zk.machine</field>
        <field name="arch" type="xml">
            <list string="Biometric Machine">
                <field name="name"/>
                <field name="port_no"/>
                <field name="address_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    <record id="zk_machine_view_search" model="ir.ui.view">
        <field name="name">zk.machine.view.search</field>
        <field name="model">zk.machine</field>
        <field name="arch" type="xml">
            <search string="ZK Machine">
                <field name="name" string="Zk Machine"/>
                <searchpanel>
                    <field name="company_id" groups="base.group_multi_company" icon="fa-building"/>
                </searchpanel>
                <separator/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="address_id" string="Working Address" domain="[]" context="{'group_by': 'address_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--Menu action for attendance -->
    <record id="zk_machine_action" model="ir.actions.act_window">
        <field name="name">Attendances</field>
        <field name="res_model">zk.machine</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--Menu Items-->
    <menuitem id="zk_machine_menu_root"
              parent="hr_attendance.menu_hr_attendance_root" sequence="50"
              name="Biometric Manager"/>
    <menuitem id="zk_machine_menu" parent="zk_machine_menu_root"
              name="Device Configuration" action="zk_machine_action"
              sequence="1"/>
</odoo>
