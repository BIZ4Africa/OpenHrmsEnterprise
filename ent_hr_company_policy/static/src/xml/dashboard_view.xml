<?xml version="1.0" encoding="UTF-8"?>
<!--Extend HR Dashboard to add Company Policy button.-->
<templates id="template" xml:space="preserve">
    <t t-inherit="HrDashboardMain" t-inherit-mode="extension">
        <xpath expr="//div[@id='employee-details']" position="after">
            <div style="padding: 10px 15px;">
                <button type="button" class="btn oe_company_policy" t-on-click="actionOpenCompanyPolicy">
                    Company Policy
                </button>
            </div>
        </xpath>
    </t>
</templates>