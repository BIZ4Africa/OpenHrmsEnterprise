<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--    Inherited hr contract form view to add extra fields-->
    <record id="hr_contract_view_form" model="ir.ui.view">
        <field name="name">hr.contract.view.form.inherit.ent.ohrms.overtime</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='salary']" position="after">
                <group string="Overtime">
                    <label for="over_day"/>
                    <div class="o_row" name="day_wage">
                        <field name="over_day"/>
                        <span>/day</span>
                    </div>
                    <label for="over_hour"/>
                    <div class="o_row" name="hour_wage">
                        <field name="over_hour"/>
                        <span>/hour</span>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
