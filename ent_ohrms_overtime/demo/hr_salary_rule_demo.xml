<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!--    Salary Rule Demo-->
        <record id="hr_salary_rule_overtime" model="hr.salary.rule">
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="name">Overtime</field>
            <field name="sequence">199</field>
            <field name="code">OT100</field>
            <field name="condition_select">python</field>
            <field name="condition_python">result = 'OT100' in inputs</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = inputs['OT100'].amount</field>
            <field name="struct_id" ref="hr_payroll_salary_structure_overtime"/>
        </record>
    </data>
</odoo>
