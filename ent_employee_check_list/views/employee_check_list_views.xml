<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Employee checklist views-->
    <record id='employee_checklist_view_list' model='ir.ui.view'>
        <field name="name">employee.checklist.view.list</field>
        <field name="model">employee.checklist</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="document_type"/>
            </list>
        </field>
    </record>
    <!--    Employee checklist action-->
    <record id="employee_checklist_action" model="ir.actions.act_window">
        <field name="name">Checklists</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">employee.checklist</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a Checklist
            </p>
        </field>
    </record>
    <!--Menuitem for the model employee.checklist-->
    <menuitem id="employee_checklist_menu" name="Checklists"
              parent="hr.menu_human_resources_configuration" sequence="3"
              action="employee_checklist_action"/>
</odoo>
