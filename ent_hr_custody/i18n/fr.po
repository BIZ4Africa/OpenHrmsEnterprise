"                                                            <br/>\n"
"                                                            <br/>\n"
"                                                            Regards,\n"
"                                                            <br/>\n"
"                                                            <t t-out=\"object.company_id.name or ''\">\n"
"                                                                My Company\n"
"                                                            </t>\n"
"                                                        </div>\n"
"                                                    </td>\n"
"                                                </tr>\n"
