"                                                            <br/>\n"
"                                                            <br/>\n"
"                                                            This Mail is to\n"
"                                                            inform\n"
"                                                            that You are in\n"
"                                                            possession of the\n"
"                                                            company asset\n"
"                                                            <b>\n"
"                                                                \"\n"
"                                                                <t t-out=\"object.custody_name.name or ''\">\n"
"                                                                    Company\n"
"                                                                    Property\n"
"                                                                </t>\n"
"                                                                \"\n"
"                                                            </b>\n"
"                                                            since the Return\n"
"                                                            Date\n"
"                                                            <b style=\"color:red;\">\n"
"                                                                <t t-out=\"object.return_date or ''\">\n"
"                                                                    2022/01/30\n"
"                                                                </t>\n"
"                                                            </b>\n"
"                                                            <br/>\n"
"                                                            <br/>\n"
"                                                            Please kindly return\n"
"                                                            the\n"
