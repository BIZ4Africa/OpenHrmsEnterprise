"                                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"min-width: 590px; background-color: white; font-size: 11px; padding: 0px 8px 0px 8px; border-collapse:separate;\">\n"
"                                                <tr>\n"
"                                                    <td valign=\"middle\" align=\"left\">\n"
"                                                        <t t-out=\"object.company_id.name or ''\">\n"
"                                                            YourCompany\n"
"                                                        </t>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                                <tr>\n"
"                                                    <td valign=\"middle\" align=\"left\" style=\"opacity: 0.7;\">\n"
"                                                        <t t-out=\"object.company_id.phone or ''\">\n"
"                                                            +1 650-123-4567\n"
"                                                        </t>\n"
"                                                        <t t-if=\"object.company_id.email\">\n"
"                                                            |\n"
"                                                            <a t-attf-href=\"'mailto:%s' % {{ object.company_id.email }}\" style=\"text-decoration:none; color: #454748;\">\n"
"                                                                <t t-out=\"object.company_id.email or ''\">\n"
"                                                                    info@yourcompany.com\n"
"                                                                </t>\n"
"                                                            </a>\n"
"                                                        </t>\n"
"                                                        <t t-if=\"object.company_id.website\">\n"
"                                                            |\n"
"                                                            <a t-attf-href=\"'%s' % {{ object.company_id.website }}\" style=\"text-decoration:none; color: #454748;\">\n"
"                                                                <t t-out=\"object.company_id.website or ''\">\n"
"                                                                    http://www.example.com\n"
"                                                                </t>\n"
"                                                            </a>\n"
"                                                        </t>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                            </table>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"            "
msgstr ""
"<p>Cher ${(object.employee.name)},<br/><br/>\n"
"                          Vous êtes en possession du patrimoine de l'entreprise\n"
"                          <strong>\"${(object.custody_name.name)}\"</strong>\n"
"                          depuis <strong>${(object.return_date)}.</strong><br/><br/>\n"
"                          Veuillez restituer la propriété dès que possible.<br/><br/></p>\n"
"                          Cordialement,<br/><br/>\n"
"                          ${(object.company_id.name)}"

